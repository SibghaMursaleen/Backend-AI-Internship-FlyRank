      "id": "47a45cde-ed44-4253-a26c-101684f40553",
      "name": "Wait - Human in Loop",
      "webhookId": "371ec73d-1871-4e7b-a51d-92faca9b5439"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an AI study assistant.\n\nThe following summary has been reviewed and approved by a human reviewer.\n\nApproved Summary:\n{{ $('Stage 2 - Review').item.json.approved_summary}}\n\nReview Results:\n{{ $json.text }}\n\nSource URL:\n{{ $('Edit Fields').item.json.articleURL }}\n\nCreate a professional study report.\n\nInclude exactly these sections:\n\n# Source\n\n# Executive Summary\n\n# Key Concepts\n\n# Technical Details\n\n# Practical Takeaways\n\n# Human Review Outcome\n\n# Confidence\n\nRequirements:\n- Use only the approved summary and review results.\n- Do not invent new information.\n- Produce clean Markdown formatting.\n- If the review decision was \"Reject\", clearly state that the report should not be used until corrections are made.",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        112,
        -240
