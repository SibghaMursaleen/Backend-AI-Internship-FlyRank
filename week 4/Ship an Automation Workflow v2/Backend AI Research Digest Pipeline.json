      "id": "182df00f-b4fb-4a49-adbf-6c244174b940",
      "name": "Stage 3 - Final Report"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are reviewing a summary that has already been edited and approved by a human.\n\nApproved Summary:\n{{ $json.approved_summary }}\n\nDecision:\n{{ $json.decision }}\n\nReviewer Comments:\n{{ $json.reviewer_comments }}\n\nInstructions:\n\n- If the decision is \"Reject\", explain why the summary should not be used and recommend improvements.\n\n- If the decision is \"Approve\", verify that the summary is clear, technically accurate, and well structured.\n\nReturn your response in this format:\n\n## Review Status\n\n## Strengths\n\n## Remaining Issues\n\n## Final Recommendation\n\nKeep the review concise and do not invent information that is not present in the approved summary.",
        "batching": {}
      },
