      "parameters": {
        "promptType": "define",
        "text": "=You are an AI study assistant.\n\nAnalyze the article below and create structured study notes.\n\nSource URL:\n{{ $json.articleURL }}\n\nArticle:\n{{ $json.article }}\n\nReturn the following sections:\n\n## Source\nWrite the URL.\n\n## Main Topic\n\n## Key Concepts\n\n## Important Technical Details\n\n## Practical Takeaways\n\n## Confidence\n(High, Medium, or Low)",
        "batching": {}
      },
