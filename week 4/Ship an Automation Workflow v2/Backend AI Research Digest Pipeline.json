        "resume": "form",
        "formTitle": "Human Review Required",
        "formDescription": "Review the AI-generated summary. If it is accurate and complete, approve it. If necessary, edit the summary before submitting.",
        "formFields": {
          "values": [
            {
              "fieldLabel": "approved_summary",
              "fieldType": "textarea",
              "placeholder": "Paste or edit the AI-generated summary here.",
              "requiredField": true
            },
            {
              "fieldLabel": "decision",
              "fieldType": "dropdown",
              "fieldOptions": {
                "values": [
                  {
                    "option": "Approved"
                  },
                  {
                    "option": "Reject"
                  }
                ]
              },
              "requiredField": true
            },
            {
              "fieldLabel": "reviewer_comments",
              "fieldType": "textarea",
              "placeholder": "Enter any comments or corrections."
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.wait",
